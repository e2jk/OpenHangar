# Copy this file to .env and fill in the values before running docker compose.

# ── Database ──────────────────────────────────────────────────────────────────
OPENHANGAR_POSTGRES_IMAGE_TAG=postgres:18-alpine
OPENHANGAR_DEMO_DB_HOSTNAME=openhangar-demo-db
OPENHANGAR_DEMO_POSTGRES_DB=openhangar_demo
OPENHANGAR_DEMO_POSTGRES_USER=openhangar_demo
OPENHANGAR_DEMO_POSTGRES_PASSWORD=change-me-strong-password

# ── Web app ───────────────────────────────────────────────────────────────────
OPENHANGAR_DEMO_IMAGE=ghcr.io/e2jk/openhangar:latest
OPENHANGAR_DEMO_WEB_CONTAINER=openhangar-demo-web
OPENHANGAR_DEMO_HOSTNAME=demo.openhangar.aero
OPENHANGAR_DEMO_SECRET_KEY=change-me-secret-key-min-32-chars

# ── Demo behaviour ────────────────────────────────────────────────────────────
DEMO_SLOT_COUNT=20
# Written by refresh.sh before each wipe; ISO-8601 UTC e.g. 2024-06-01T09:07:00Z
DEMO_NEXT_WIPE_UTC=
