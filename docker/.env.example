# Copy this file to .env and fill in the values before running docker compose.

# ── Traefik ───────────────────────────────────────────────────────────────────
TRAEFIK_IMAGE_TAG=traefik:v3
TRAEFIK_LOG_LEVEL=WARN
TRAEFIK_ACME_EMAIL=admin@example.com
# Optional: expose the Traefik dashboard at this hostname
TRAEFIK_HOSTNAME=traefik.example.com
# Generate with: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
TRAEFIK_BASIC_AUTH=admin:$$2y$$05$$replacethiswitharealhash

# ── Database ──────────────────────────────────────────────────────────────────
OPENHANGAR_POSTGRES_IMAGE_TAG=postgres:18-alpine
OPENHANGAR_POSTGRES_HOSTNAME=openhangar-db
OPENHANGAR_POSTGRES_DB=openhangar
OPENHANGAR_POSTGRES_USER=openhangar
OPENHANGAR_POSTGRES_PASSWORD=change-me-strong-db-password

# ── Web app ───────────────────────────────────────────────────────────────────
OPENHANGAR_IMAGE=ghcr.io/e2jk/openhangar:latest
OPENHANGAR_HOSTNAME=hangar.example.com
# Generate with: openssl rand -hex 32
OPENHANGAR_SECRET_KEY=change-me-secret-key-min-32-chars
# Generate with: openssl rand -hex 32  (store separately from the backups)
OPENHANGAR_BACKUP_ENCRYPTION_KEY=change-me-backup-encryption-key

# ── Email (optional — enables in-app notifications) ───────────────────────────
# OPENHANGAR_SMTP_HOST=smtp.example.com
# OPENHANGAR_SMTP_PORT=587
# OPENHANGAR_SMTP_USER=noreply@example.com
# OPENHANGAR_SMTP_PASSWORD=change-me-smtp-password
# OPENHANGAR_SMTP_USE_TLS=true
# OPENHANGAR_SMTP_FROM_ADDRESS=noreply@example.com
# OPENHANGAR_SMTP_FROM_NAME=OpenHangar

# ── Maps (optional — enables aviation map overlay) ───────────────────────────
# OPENHANGAR_OPENAIP_API_KEY=your-openaip-api-key

# ── Airworthiness sync (optional) ────────────────────────────────────────────
# Hour (UTC, 0–23) at which the daily EASA airworthiness sync runs (ADs, SIBs).
# If unset, a random hour between 01:00 and 05:00 UTC is chosen at startup so
# that different instances do not all hit the EASA servers at the same time.
# OPENHANGAR_AIRWORTHINESS_EASA_SYNC_HOUR=3

# ── Security alerting (optional) ─────────────────────────────────────────────
# OPENHANGAR_ALERT_NTFY_TOPIC_URL=https://ntfy.sh/your-private-topic
# OPENHANGAR_ALERT_EMAIL_TO=admin@example.com
# OPENHANGAR_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
