msgid "Overhaul reserve accrual must be a non-negative number."
msgstr "La provision pour révision doit être un nombre non négatif."

#: app/aircraft/routes.py:410
msgid "Oil consumption warning threshold must be a non-negative number."
msgstr ""
"Le seuil d'alerte de consommation d'huile doit être un nombre positif ou "
"nul."

#: app/aircraft/routes.py:448
#, python-format
msgid "%(reg)s saved."
msgstr "%(reg)s enregistré."

#: app/aircraft/routes.py:468
#, python-format
msgid ""
"%(reg)s has been archived — its history stays available, but it no longer "
"appears in the active fleet."
msgstr ""
"%(reg)s a été archivé — son historique reste disponible, mais il n'apparaît "
"plus dans la flotte active."

