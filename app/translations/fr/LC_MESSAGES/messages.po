#: app/aircraft/routes.py:352
msgid "Registration is required."
msgstr "L'immatriculation est obligatoire."

#: app/aircraft/routes.py:354 app/aircraft/routes.py:612
msgid "Manufacturer is required."
msgstr "Le fabricant est obligatoire."

#: app/aircraft/routes.py:356 app/aircraft/routes.py:614
msgid "Model is required."
msgstr "Le modèle est obligatoire."

#: app/aircraft/routes.py:364
msgid "Year must be a valid 4-digit year."
msgstr "L'année doit être une année valide à 4 chiffres."

#: app/aircraft/routes.py:373
msgid "Flight counter offset must be a non-negative number."
msgstr "Le décalage du compteur de vol doit être un nombre positif ou nul."

#: app/aircraft/routes.py:382
msgid "Fuel consumption must be a non-negative number."
msgstr "La consommation de carburant doit être un nombre positif ou nul."

#: app/aircraft/routes.py:391
msgid "Insurance expiry must be a valid date (YYYY-MM-DD)."
msgstr ""
"La date d'expiration de l'assurance doit être une date valide (AAAA-MM-JJ)."

