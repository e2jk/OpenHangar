#!/usr/bin/env bash
# Pre-push hook: run Ruff linting and check for untranslated strings.
# Mirrors the hard-fail logic in .github/workflows/ci.yml.
#
# Install once per clone:
#   git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTHON="$REPO_ROOT/.venv/bin/python"
PYBABEL="$REPO_ROOT/.venv/bin/pybabel"
RUFF="$REPO_ROOT/.venv/bin/ruff"
MYPY="$REPO_ROOT/.venv/bin/mypy"
BANDIT="$REPO_ROOT/.venv/bin/bandit"

if [ ! -x "$PYTHON" ]; then
  echo "[pre-push] .venv not found — skipping checks"
  exit 0
fi

# ── Ruff ──────────────────────────────────────────────────────────────────────
if [ -x "$RUFF" ]; then
  echo "[pre-push] Running Ruff linter..."
  "$RUFF" check "$REPO_ROOT"
  echo "[pre-push] Running Ruff formatter check..."
  "$RUFF" format --check "$REPO_ROOT"
else
  echo "[pre-push] ruff not found in .venv — skipping (run: pip install ruff)"
fi

# ── mypy ──────────────────────────────────────────────────────────────────────
if [ -x "$MYPY" ]; then
  echo "[pre-push] Running mypy type-checker..."
  "$MYPY" "$REPO_ROOT/app/"
else
  echo "[pre-push] mypy not found in .venv — skipping (run: pip install mypy)"
fi

# ── bandit ────────────────────────────────────────────────────────────────────
if [ -x "$BANDIT" ]; then
  echo "[pre-push] Running bandit security scan..."
  "$BANDIT" -r "$REPO_ROOT/app/" -lll -i --exclude "$REPO_ROOT/app/tests" -q
else
  echo "[pre-push] bandit not found in .venv — skipping (run: pip install bandit)"
fi

# ── Translations ──────────────────────────────────────────────────────────────
POT="$(mktemp /tmp/messages_prepush_XXXXXX.pot)"
trap 'rm -f "$POT"' EXIT

"$PYBABEL" extract -F "$REPO_ROOT/babel.cfg" -o "$POT" "$REPO_ROOT" >/dev/null 2>&1

"$PYTHON" - "$REPO_ROOT" "$POT" <<'PYEOF'
import sys, os, tempfile, shutil, subprocess, pathlib
import polib

repo = pathlib.Path(sys.argv[1])
pot  = sys.argv[2]
pybabel = str(repo / ".venv/bin/pybabel")

fail = False
for lang_dir in sorted((repo / "app/translations").iterdir()):
    if not lang_dir.is_dir():
        continue
    lang = lang_dir.name
    with tempfile.TemporaryDirectory() as tmp:
        po_tmp = pathlib.Path(tmp, lang, "LC_MESSAGES", "messages.po")
        po_tmp.parent.mkdir(parents=True)
        shutil.copy(lang_dir / "LC_MESSAGES/messages.po", po_tmp)
        subprocess.run(
            [pybabel, "update", "-i", pot, "-d", tmp, "-l", lang, "--no-fuzzy-matching"],
            check=True, capture_output=True,
        )
        count = len(polib.pofile(str(po_tmp)).untranslated_entries())
    if count:
        print(f"[pre-push] ERROR: {count} untranslated {lang} string(s) — translate and commit messages.po before pushing.")
        fail = True

if fail:
    sys.exit(1)
print("[pre-push] Translations OK.")
PYEOF

python_exit=$?
exit $python_exit
