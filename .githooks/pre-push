#!/usr/bin/env bash
# Pre-push hook: run Ruff linting, pip-audit, and check for untranslated/fuzzy strings.
# Mirrors the hard-fail logic in .github/workflows/ci.yml.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Run from time to time to sync local tooling versions to what this repo
# pins (requirements/dev.txt for pip tools, ci.yml for actionlint) — git
# itself never passes these flags, so this is safe to leave in a hook:
#   bash .githooks/pre-push --update

set -uo pipefail

UPDATE_MODE=false
for arg in "$@"; do
  case "$arg" in
    --update|--install) UPDATE_MODE=true ;;
  esac
done

FAILED_STEPS=()

run_step() {
  # run_step <label> <cmd> [args...]
  local label="$1"; shift
  if "$@"; then
    :
  else
    FAILED_STEPS+=("$label")
  fi
}

run_step_quiet() {
  # run_step_quiet [--detail <grep -E pattern>] <label> <cmd> [args...]
  # Like run_step, but for CLI tools whose own success output is noisy,
  # unprefixed, and inconsistently coloured (ruff/mypy/bandit/zizmor/
  # actionlint/pip-audit all differ). Captures stdout+stderr; on success it's
  # discarded in favour of one uniform "[label] OK" line — unless --detail is
  # given, in which case the last match of that pattern in the tool's output
  # is appended (e.g. zizmor's own "(N ignored)" suppression count is
  # meaningful, unlike ruff's "All checks passed!"). On failure the tool's
  # full raw output is dumped, since that's exactly when the detail (and its
  # colouring/formatting) is worth keeping.
  local detail_pattern=""
  if [ "$1" = "--detail" ]; then
    detail_pattern="$2"; shift 2
  fi
  local label="$1"; shift
  local output
  if output="$("$@" 2>&1)"; then
    local detail=""
    if [ -n "$detail_pattern" ]; then
      detail="$(echo "$output" | grep -oE "$detail_pattern" | tail -1)"
    fi
    echo "[$label] OK${detail:+ $detail}"
  else
    FAILED_STEPS+=("$label")
    echo "[$label] FAILED"
    [ -n "$output" ] && echo "$output"
  fi
}

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTHON="$REPO_ROOT/.venv/bin/python"
PYBABEL="$REPO_ROOT/.venv/bin/pybabel"
RUFF="$REPO_ROOT/.venv/bin/ruff"
MYPY="$REPO_ROOT/.venv/bin/mypy"
BANDIT="$REPO_ROOT/.venv/bin/bandit"
PIP_AUDIT="$REPO_ROOT/.venv/bin/pip-audit"
ZIZMOR="$REPO_ROOT/.venv/bin/zizmor"
DEV_TXT="$REPO_ROOT/requirements/dev.txt"
CI_YML="$REPO_ROOT/.github/workflows/ci.yml"

# ── Version-pin lookups: compare local installs against what this repo pins,
# no network calls — "are you in sync with what CI actually runs", not "is
# there a newer upstream release". ─────────────────────────────────────────────
_pinned_pip_version() {
  grep -E "^$1==" "$DEV_TXT" 2>/dev/null | head -1 | cut -d= -f3
}

_installed_pip_version() {
  [ -x "$PYTHON" ] || return
  "$REPO_ROOT/.venv/bin/pip" show "$1" 2>/dev/null | awk -F': ' '/^Version:/{print $2}'
}

_pinned_actionlint_version() {
  grep -oE 'actionlint_[0-9]+\.[0-9]+\.[0-9]+_linux_amd64\.tar\.gz' "$CI_YML" 2>/dev/null \
    | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+'
}

_pinned_actionlint_sha256() {
  grep -oE '[0-9a-f]{64}  actionlint\.tar\.gz' "$CI_YML" 2>/dev/null | head -1 | cut -d' ' -f1
}

if [ ! -x "$PYTHON" ]; then
  echo "[pre-push] .venv not found — skipping checks"
  exit 0
fi

if $UPDATE_MODE; then
  echo "[pre-push --update] Syncing local tooling to the versions this repo pins..."
  echo "[pre-push --update] pip install -r requirements/dev.txt"
  "$REPO_ROOT/.venv/bin/pip" install --quiet -r "$DEV_TXT"

  AL_VERSION="$(_pinned_actionlint_version)"
  AL_SHA="$(_pinned_actionlint_sha256)"
  if [ -n "$AL_VERSION" ] && [ -n "$AL_SHA" ]; then
    echo "[pre-push --update] Installing actionlint v${AL_VERSION} to ~/.local/bin..."
    mkdir -p "$HOME/.local/bin"
    TMP_TGZ="$(mktemp)"
    if curl -sfL -o "$TMP_TGZ" "https://github.com/rhysd/actionlint/releases/download/v${AL_VERSION}/actionlint_${AL_VERSION}_linux_amd64.tar.gz" \
       && echo "${AL_SHA}  ${TMP_TGZ}" | sha256sum -c - >/dev/null 2>&1; then
      tar xzf "$TMP_TGZ" -C "$HOME/.local/bin" actionlint
      echo "[pre-push --update] actionlint v${AL_VERSION} installed."
    else
      echo "[pre-push --update] WARNING: actionlint download/checksum failed — left untouched."
    fi
    rm -f "$TMP_TGZ"
  else
    echo "[pre-push --update] Could not determine the pinned actionlint version from ci.yml — skipping."
  fi

  echo "[pre-push --update] Done. Continuing with the normal checks..."
  echo ""
fi

# ── Ruff ──────────────────────────────────────────────────────────────────────
if [ -x "$RUFF" ]; then
  echo "[ruff-lint] Running Ruff linter..."
  run_step_quiet "ruff-lint"      "$RUFF" check "$REPO_ROOT"
  echo "[ruff-format] Running Ruff formatter check..."
  run_step_quiet "ruff-format"    "$RUFF" format --check "$REPO_ROOT"
else
  echo "[ruff] not found in .venv — skipping (run: pip install ruff)"
fi

# ── mypy ──────────────────────────────────────────────────────────────────────
if [ -x "$MYPY" ]; then
  echo "[mypy] Running mypy type-checker..."
  run_step_quiet "mypy"           "$MYPY" "$REPO_ROOT/app/"
else
  echo "[mypy] not found in .venv — skipping (run: pip install mypy)"
fi

# ── bandit ────────────────────────────────────────────────────────────────────
if [ -x "$BANDIT" ]; then
  echo "[bandit] Running bandit security scan..."
  run_step_quiet "bandit"         "$BANDIT" -c "$REPO_ROOT/pyproject.toml" -r "$REPO_ROOT/app/" -ll -i -q
else
  echo "[bandit] not found in .venv — skipping (run: pip install bandit)"
fi

# ── zizmor ────────────────────────────────────────────────────────────────────
if [ -x "$ZIZMOR" ]; then
  echo "[zizmor] Linting GitHub Actions workflows..."
  run_step_quiet --detail '\([0-9]+ ignored\)' "zizmor" "$ZIZMOR" -q --persona=pedantic --offline "$REPO_ROOT/.github/"
else
  echo "[zizmor] not found in .venv — skipping (run: pip install zizmor)"
fi

# ── actionlint ────────────────────────────────────────────────────────────────
if command -v actionlint >/dev/null 2>&1; then
  echo "[actionlint] Linting GitHub Actions workflows..."
  run_step_quiet "actionlint"     actionlint -color "$REPO_ROOT/.github/workflows/"*.yml
else
  echo "[actionlint] not found on PATH — skipping (run: bash <(curl -sf https://raw.githubusercontent.com/rhysd/actionlint/main/scripts/download-actionlint.bash) latest ~/.local/bin)"
fi

# ── Coverage (quick check against last run, if recent) ────────────────────────
COV_XML="$REPO_ROOT/coverage.xml"
COV_MAX_AGE=600  # seconds — ignore reports older than 10 minutes
if [ -f "$COV_XML" ]; then
  file_age=$(( $(date +%s) - $(date -r "$COV_XML" +%s) ))
  if [ "$file_age" -le "$COV_MAX_AGE" ]; then
    echo "[coverage] Checking coverage from last test run (${file_age}s ago)..."
    run_step "coverage"     "$PYTHON" - "$COV_XML" <<'COVEOF'
import sys, xml.etree.ElementTree as ET
rate = float(ET.parse(sys.argv[1]).getroot().attrib.get("line-rate", 1))
pct = round(rate * 100, 2)
if rate < 1.0:
    print(f"[coverage] ERROR: coverage is {pct}% — run the full test suite and fix gaps before pushing.")
    sys.exit(1)
print(f"[coverage] Coverage OK ({pct}%).")
COVEOF
  else
    echo "[coverage] Report is ${file_age}s old (> ${COV_MAX_AGE}s) — skipping coverage check."
  fi
else
  echo "[coverage] No coverage.xml found — skipping coverage check."
fi

# ── pip-audit ─────────────────────────────────────────────────────────────────
if [ -x "$PIP_AUDIT" ]; then
  echo "[pip-audit] Auditing dependencies for known vulnerabilities..."
  run_step_quiet "pip-audit"     "$PIP_AUDIT" --local
else
  echo "[pip-audit] not found in .venv — skipping (run: pip install pip-audit)"
fi

# ── Migration chain ───────────────────────────────────────────────────────────
echo "[check-migrations] Checking migration chain..."
run_step "check-migrations" "$PYTHON" "$REPO_ROOT/scripts/check_migrations.py"

# ── Translations ──────────────────────────────────────────────────────────────
echo "[translations] Checking catalogs..."
run_step "translations" "$PYTHON" "$REPO_ROOT/scripts/check_translations.py"

# ── Local tool version drift (non-blocking) ────────────────────────────────────
STALE_TOOLS=()
for pkg in ruff mypy bandit pip-audit zizmor; do
  pinned="$(_pinned_pip_version "$pkg")"
  installed="$(_installed_pip_version "$pkg")"
  if [ -n "$pinned" ] && [ -n "$installed" ] && [ "$pinned" != "$installed" ]; then
    STALE_TOOLS+=("$pkg ($installed -> $pinned)")
  fi
done
if command -v actionlint >/dev/null 2>&1; then
  al_pinned="$(_pinned_actionlint_version)"
  al_installed="$(actionlint -version 2>/dev/null | head -1)"
  if [ -n "$al_pinned" ] && [ -n "$al_installed" ] && [ "$al_pinned" != "$al_installed" ]; then
    STALE_TOOLS+=("actionlint ($al_installed -> $al_pinned)")
  fi
fi
if [ "${#STALE_TOOLS[@]}" -gt 0 ]; then
  echo ""
  echo "[pre-push] Locally installed tool(s) behind what this repo pins: ${STALE_TOOLS[*]}"
  echo "[pre-push] Run 'bash .githooks/pre-push --update' to sync."
fi

# ── Final summary ─────────────────────────────────────────────────────────────
if [ "${#FAILED_STEPS[@]}" -gt 0 ]; then
  echo ""
  echo "[pre-push] FAILED steps: ${FAILED_STEPS[*]}"
  exit 1
fi
