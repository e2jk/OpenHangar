# Exclude everything from the build context by default,
# then explicitly allow only what the Dockerfile COPYs.
**

!docker/
!app/
!demo/
!requirements/
!scripts/install_vendor_assets.py

# Local-build hygiene — dev artefacts admitted by !app/ that must never reach
# the image (CI builds from a fresh clone and never has them):
app/**/__pycache__
app/instance/
app/static/vendor/
app/translations/**/*.mo
